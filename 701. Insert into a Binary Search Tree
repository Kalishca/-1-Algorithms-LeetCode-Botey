class Solution:
    def insertIntoBST(self, root, val):
        # Если дерево пусто, создаём новый узел и возвращаем его
        if not root:
            return TreeNode(val)
        
        cur = root
        while True:
            if val < cur.val:
                # Вставляемое значение меньше — идём влево
                if cur.left is None:
                    cur.left = TreeNode(val)
                    break
                cur = cur.left
            else:
                # Вставляемое значение больше — идём вправо
                if cur.right is None:
                    cur.right = TreeNode(val)
                    break
                cur = cur.right
        
        return root
