class Solution:
    def coinChange(self, coins: list[int], amount: int) -> int:
        # Инициализируем таблицу значением amount + 1 (условная бесконечность),
        # так как количество монет не может превышать саму сумму.
        dp = [amount + 1] * (amount + 1)
        
        # Базовый случай: для суммы 0 нужно 0 монет
        dp[0] = 0
        
        # Перебираем все возможные суммы от 1 до целевого значения
        for i in range(1, amount + 1):
            # Для каждой суммы проверяем каждую доступную монету
            for coin in coins:
                # Если номинал монеты не превышает текущую сумму
                if i - coin >= 0:
                    # Обновляем оптимальное решение для суммы i:
                    # выбираем минимум между текущим значением и вариантом (1 монета + остаток)
                    dp[i] = min(dp[i], dp[i - coin] + 1)
        
        # Если значение осталось "бесконечным", значит сумму собрать нельзя
        return dp[amount] if dp[amount] != amount + 1 else -1
