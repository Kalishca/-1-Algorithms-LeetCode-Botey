class Solution:
    def canPartition(self, nums: list[int]) -> bool:
        total_sum = sum(nums)
        
        # Если сумма всех чисел нечетная, разделить её на две равные 
        # целые части невозможно.
        if total_sum % 2 != 0:
            return False
        
        # Целевая сумма для одной подгруппы
        target = total_sum // 2
        
        # Оптимизация памяти: используем одномерный массив вместо двумерного.
        # dp[i] будет хранить True, если сумма i достижима.
        dp = [False] * (target + 1)
        dp[0] = True # Нулевая сумма всегда достижима (пустой поднабор)
        
        # Перебираем каждое число из входного массива
        for num in nums:
            # Идем по суммам в обратном порядке (от target до num).
            # Это критически важно для оптимизации памяти, чтобы не использовать 
            # одно и то же число несколько раз для одной суммы.
            for i in range(target, num - 1, -1):
                # Если сумма (i - num) была достижима, то теперь достижима и сумма i
                if dp[i - num]:
                    dp[i] = True
            
            # Если целевая сумма уже найдена, можно закончить раньше
            if dp[target]:
                return True
                    
        return dp[target]
